# =============================================================================
# Environment variable template — copy to .env and fill in secrets
# NEVER commit .env to version control
# =============================================================================

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
DEBUG=false
SECRET_KEY=replace-with-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=liuyao
POSTGRES_USER=liuyao
POSTGRES_PASSWORD=replace-with-secure-password

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_ANALYSIS=86400
CACHE_TTL_HEXAGRAM_LIST=300
CACHE_TTL_STATS=60

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=4
ENGINE_THREAD_POOL_SIZE=8

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json        # json | console

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list; use * for development only
CORS_ORIGINS=["*"]
